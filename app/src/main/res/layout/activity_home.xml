<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeActivity"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="5dp">
    <include
        layout="@layout/text_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:text="@string/select_date"
        android:textSize="16sp"
        android:layout_marginVertical="5dp"/>
    <HorizontalScrollView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <RadioGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:id="@+id/rgDaySelector">
                <RadioButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_rectangle"
                    android:backgroundTint="@color/radio_button_bg"
                    android:text="@string/today"
                    android:textColor="@color/radio_button"
                    android:checked="true"
                    app:buttonTint="@color/radio_button"
                    android:paddingHorizontal="10dp"
                    android:textSize="18sp"
                    android:id="@+id/btnToday"/>
                <RadioButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_rectangle"
                    android:backgroundTint="@color/radio_button_bg"
                    android:text="@string/tomorrow"
                    android:textColor="@color/radio_button"
                    android:checked="false"
                    app:buttonTint="@color/radio_button"
                    android:paddingHorizontal="10dp"
                    android:textSize="18sp"
                    android:layout_marginStart="10dp"
                    android:id="@+id/btnTomorrow"/>
            </RadioGroup>
        </LinearLayout>
    </HorizontalScrollView>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/now_showing"
        android:textColor="@color/text_primary"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_marginVertical="20dp"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout android:id="@+id/movie1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/movie_card"
                android:padding="20dp"
                android:layout_marginBottom="10dp">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/movie1"
                    android:scaleType="fitXY"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="160dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie1"
                        android:textColor="@color/text_primary"
                        android:textSize="30sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie1_genre"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginVertical="15dp"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:text="@string/book_seats"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="10dp"
                            android:id="@+id/bookBtn1"/>
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="0dp"
                            android:textSize="16sp"
                            android:layout_height="match_parent"
                            android:layout_weight="2"
                            android:padding="0dp"
                            android:textColor="@color/text_black"
                            app:backgroundTint="@color/secondary"
                            android:layout_marginStart="10dp"
                            android:text="@string/trailer"
                            android:id="@+id/trailerBtn1"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:id="@+id/movie2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/movie_card"
                android:padding="20dp"
                android:layout_marginBottom="10dp">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/movie2"
                    android:scaleType="fitXY"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="160dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie2"
                        android:textColor="@color/text_primary"
                        android:textSize="30sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie2_genre"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginVertical="15dp"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:text="@string/book_seats"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="10dp"
                            android:id="@+id/bookBtn2"/>
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="0dp"
                            android:textSize="16sp"
                            android:layout_height="match_parent"
                            android:layout_weight="2"
                            android:padding="0dp"
                            android:textColor="@color/text_black"
                            app:backgroundTint="@color/secondary"
                            android:layout_marginStart="10dp"
                            android:text="@string/trailer"
                            android:id="@+id/trailerBtn2"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:id="@+id/movie3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/movie_card"
                android:padding="20dp"
                android:layout_marginBottom="10dp">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/movie3"
                    android:scaleType="fitXY"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="160dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie3"
                        android:textColor="@color/text_primary"
                        android:textSize="30sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie3_genre"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginVertical="15dp"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:text="@string/book_seats"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="10dp"
                            android:id="@+id/bookBtn3"/>
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="0dp"
                            android:textSize="16sp"
                            android:layout_height="match_parent"
                            android:layout_weight="2"
                            android:padding="0dp"
                            android:textColor="@color/text_black"
                            app:backgroundTint="@color/secondary"
                            android:layout_marginStart="10dp"
                            android:text="@string/trailer"
                            android:id="@+id/trailerBtn3"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:id="@+id/movie4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/movie_card"
                android:padding="20dp"
                android:layout_marginBottom="10dp">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/movie4"
                    android:scaleType="fitXY"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="160dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie4"
                        android:textColor="@color/text_primary"
                        android:textSize="30sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/movie4_genre"
                        android:textColor="@color/text_secondary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginVertical="15dp"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:text="@string/book_seats"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="10dp"
                            android:id="@+id/bookBtn4"/>
                        <com.google.android.material.button.MaterialButton
                            android:layout_width="0dp"
                            android:textSize="16sp"
                            android:layout_height="match_parent"
                            android:layout_weight="2"
                            android:padding="0dp"
                            android:textColor="@color/text_black"
                            app:backgroundTint="@color/secondary"
                            android:layout_marginStart="10dp"
                            android:text="@string/trailer"
                            android:id="@+id/trailerBtn4"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>